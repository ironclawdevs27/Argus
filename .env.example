# GODMODE Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to source control.

# ── Slack (optional) ───────────────────────────────────────────────────────────
# Leave ALL Slack vars unset to enable Slack-optional mode: Argus will generate a
# local report.html (all findings + inline screenshots) and open it in the browser.
#
# Bot User OAuth Token from your Slack App (must start with xoxb-)
# Get from: api.slack.com/apps → Your App → OAuth & Permissions → Bot User OAuth Token
# SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack signing secret — used to verify slash command / interaction payloads
# Get from: api.slack.com/apps → Your App → Basic Information → Signing Secret
# SLACK_SIGNING_SECRET=your-signing-secret-here

# Channel IDs (not names) — right-click channel in Slack → Copy link → last segment is the ID
# SLACK_CHANNEL_CRITICAL=C0000000000
# SLACK_CHANNEL_WARNINGS=C0000000001
# SLACK_CHANNEL_DIGEST=C0000000002

# ── Target URLs ────────────────────────────────────────────────────────────────
# Base URL of your local dev environment
TARGET_DEV_URL=http://localhost:3000
# Base URL of staging. Leave blank or remove to enable CSS-only analysis mode.
TARGET_STAGING_URL=https://staging.yourapp.com

# ── Comparison Thresholds ──────────────────────────────────────────────────────
# Pixel diff percentage above which a screenshot difference is flagged (0–100)
SCREENSHOT_DIFF_THRESHOLD=0.5

# ── Output ─────────────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports

# ── Performance ────────────────────────────────────────────────────────────────
# Number of parallel MCP clients for route crawling. Default 1 = sequential.
# Increase to cut wall-clock on large apps (e.g., ARGUS_CONCURRENCY=4).
# ARGUS_CONCURRENCY=1

# ── Server (for slash command + interaction handlers) ──────────────────────────
PORT=3001
